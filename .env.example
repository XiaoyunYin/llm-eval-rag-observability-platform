# Shared
ENVIRONMENT=local

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://frontend:5173

# Data services
POSTGRES_DB=llm_eval
POSTGRES_USER=llm_eval
POSTGRES_PASSWORD=llm_eval_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://llm_eval:llm_eval_password@postgres:5432/llm_eval

REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200

# Provider mode
PROVIDER_MODE=mock

# Optional real provider keys, intentionally blank by default.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VLLM_BASE_URL=
